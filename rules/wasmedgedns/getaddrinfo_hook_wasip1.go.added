package net

import (
	"context"
)

func init() {
	testHookLookupIP = lookupIPWithWASIGetaddrinfo
}

func lookupIPWithWASIGetaddrinfo(
	ctx context.Context,
	fn func(context.Context, string, string) ([]IPAddr, error),
	network string,
	host string,
) ([]IPAddr, error) {
	return lookupAddr(ctx, network, host)
}
